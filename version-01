#include <iostream>
#include <cmath>
using namespace std;

int main() {
    char op;
    double a, b;

    cout << "Enter operator (+, -, *, /, ^, s for sqrt): ";
    cin >> op;

    if (op == 's') {
        cout << "Enter number: ";
        cin >> a;
        cout << "Result: " << sqrt(a) << endl;
    } else {
        cout << "Enter a : ";
        cin >> a ;
        cout << "Enter b : ";
        cin >> b;

        switch (op) {
            case '+':
                cout << "Result: " << a + b << endl;
                break;
            case '-':
                cout << "Result: " << a - b << endl;
                break;
            case '*':
                cout << "Result: " << a * b << endl;
                break;
            case '/':
                if (b == 0)
                    cout << "Error: Division by zero!" << endl;
                else
                    cout << "Result: " << a / b << endl;
                break;
            case '^':
                cout << "Result: " << pow(a, b) << endl;
                break;
            default:
                cout << "Invalid operator" << endl;
        }
    }

    return 0;
}
